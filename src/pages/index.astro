---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="letsbuilda.dev">
  <h1>Welcome to letsbuilda.dev</h1>
  <p>Let's build a... something. Glad you're here.</p>

  <p id="account-cta" hidden>
    <a href="/account">Go to your account &rarr;</a>
  </p>
  <p id="login-cta" hidden>Log in to view your account.</p>

  <script>
    import { isAuthenticated } from "../lib/auth";

    const authed = await isAuthenticated();
    const id = authed ? "account-cta" : "login-cta";
    document.getElementById(id)?.removeAttribute("hidden");
  </script>
</BaseLayout>
